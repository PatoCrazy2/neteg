# =========================
# PostgreSQL
# =========================
POSTGRES_DB=netegdb
POSTGRES_USER=neteguser
POSTGRES_PASSWORD=netegpassword
POSTGRES_PORT=5432

# =========================
# Redis
# =========================
REDIS_PORT=6379

# =========================
# MinIO
# =========================
MINIO_ROOT_USER=netegadmin
MINIO_ROOT_PASSWORD=netegpassword
MINIO_BUCKET=neteg-files

# =========================
# JWT & Security
# =========================
JWT_KEY=change_this_to_a_long_random_string_at_least_32_chars
JWT_ISSUER=neteg-api
JWT_AUDIENCE=neteg-client
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id
TICKET_SECRET_KEY=use_a_long_random_string_for_tickets_here

# =========================
# API & Network
# =========================
API_PORT=5000
NEXT_PUBLIC_API_URL=http://localhost:5000